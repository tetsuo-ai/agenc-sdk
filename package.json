{
  "name": "@tetsuo-ai/sdk",
  "version": "1.3.1",
  "description": "TypeScript SDK for AgenC - Privacy-preserving agent coordination on Solana",
  "packageManager": "npm@11.7.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./internal/spl-token": {
      "types": "./dist/spl-token.d.ts",
      "import": "./dist/spl-token.mjs",
      "require": "./dist/spl-token.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/spl-token.ts --format cjs,esm --dts --clean --external privacycash --external @coral-xyz/anchor",
    "api:baseline:check": "node scripts/check-api-baseline.mjs --check",
    "api:baseline:generate": "node scripts/check-api-baseline.mjs --generate",
    "errors:check": "node scripts/generate-errors.mjs --check",
    "errors:generate": "node scripts/generate-errors.mjs",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "prepublishOnly": "npm run build",
    "test:devnet:deep": "AGENC_DEVNET_DRIFT_MODE=compat node scripts/devnet-integration-deep.mjs",
    "test:devnet:deep:strict": "AGENC_DEVNET_DRIFT_MODE=strict node scripts/devnet-integration-deep.mjs",
    "test:devnet:disputes": "node scripts/devnet-disputes.mjs",
    "test:devnet:governance": "node scripts/devnet-governance.mjs",
    "test:devnet:public": "node scripts/devnet-integration.mjs",
    "test:devnet:reputation": "node scripts/devnet-reputation.mjs",
    "test:devnet:skills": "node scripts/devnet-skills.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "solana",
    "privacy",
    "zk",
    "zero-knowledge",
    "risc0",
    "router-verifier",
    "agents",
    "coordination",
    "escrow",
    "privacy-cash"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/agenc-sdk"
  },
  "homepage": "https://github.com/tetsuo-ai/agenc-sdk#readme",
  "bugs": {
    "url": "https://github.com/tetsuo-ai/agenc-sdk/issues"
  },
  "dependencies": {
    "@coral-xyz/anchor": ">=0.32.1",
    "@solana/web3.js": ">=1.98.4",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "overrides": {
    "bn.js": "^5.2.3",
    "rollup": "^4.59.0"
  },
  "resolutions": {
    "bn.js": "^5.2.3",
    "rollup": "^4.59.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.29.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
